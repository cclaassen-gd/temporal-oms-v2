# Copy to .env and adjust. See https://docs.temporal.io/

# API server
PORT=3000
NODE_ENV=development

# JWT auth (set JWT_SECRET to a long random string in production)
JWT_SECRET=dev-secret-change-in-production
JWT_EXPIRY_SECONDS=86400

# Logging (TEMPORAL_LOG_LEVEL used by src/utils/logging.ts)
TEMPORAL_LOG_LEVEL=INFO

# Temporal Server — API uses @temporalio/envconfig; worker reads these too
TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_NAMESPACE=default

# Optional: Temporal Cloud or mTLS (uncomment as needed)
# TEMPORAL_API_KEY=
# TEMPORAL_TLS=false
# TEMPORAL_TLS_SERVER_NAME=
# TEMPORAL_CONFIG_FILE=/path/to/temporal.toml
# TEMPORAL_PROFILE=default
